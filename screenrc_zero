# -----------------------------------------------------------------------------
# ~/.screenrc
# Personal GNU Screen config.
# Stay out of the way, keep old-school behaviour, sanely handle modern
# UTF-8 / 256-color terminals.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Behaviour.
# -----------------------------------------------------------------------------

# No startup banner.
startup_message off

# Enough history to be useful, still modest.
defscrollback 10000

# Quiet, predictable session behaviour.
vbell off
autodetach on

# New windows start with your current shell.
shell -$SHELL

# -----------------------------------------------------------------------------
# Terminal.
# Modern text/color baseline. Do not jump in/out of the terminal's alternate
# screen buffer, so full-screen apps don't clobber visible scrollback.
# -----------------------------------------------------------------------------

defutf8 on
term screen-256color
defbce on

termcapinfo xterm* ti@:te@
termcapinfo rxvt*  ti@:te@

# -----------------------------------------------------------------------------
# Logging.
# Timestamps only matter when logging is actually enabled for a window.
# -----------------------------------------------------------------------------

logtstamp on
logtstamp after 1

# -----------------------------------------------------------------------------
# Status bar.
# -----------------------------------------------------------------------------

hardstatus alwayslastline
hardstatus string '%{2;0}[%{+b10;0}%H%{-}][%= %{7;0}%?%-Lw%?%{+9;0}(%{+15;0}%n%f %t%?(%u)%?%{-})%{-} ^H%?%+Lw%?%= %{-}]%{+b14;0}[%m/%d/%y %c]%{-}%{-}'
