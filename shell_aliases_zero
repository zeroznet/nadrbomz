# -----------------------------------------------------------------------------
# Shared aliases and shell-safe functions for Bash and Zsh.
# Source from both ~/.zshrc and ~/.bashrc.
# -----------------------------------------------------------------------------

# Guard: interactive shells only.
case $- in
  *i*) ;;
  *) return 0 2>/dev/null || exit 0 ;;
esac

# -----------------------------------------------------------------------------
# Truecolor advert.
# Set COLORTERM=truecolor only when TERM advertises a 256-color capable
# terminfo. Skips bare xterm (PuTTY default), linux console, dumb, etc,
# so apps don't emit 24-bit SGR into terminals that can't render them.
# Respects COLORTERM that the terminal already exported (iTerm2, Alacritty).
# -----------------------------------------------------------------------------

case "$TERM" in
  *-256color|tmux*|alacritty|xterm-kitty)
    export COLORTERM="${COLORTERM:-truecolor}"
    ;;
esac

# -----------------------------------------------------------------------------
# Host detection.
# -----------------------------------------------------------------------------

__rb_host="${HOST:-${HOSTNAME:-$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo unknown)}}"

# -----------------------------------------------------------------------------
# Core aliases.
# -----------------------------------------------------------------------------

alias e='nvim'
alias glow='glow -p'
alias sdr='screen -dr'
alias lh='ssh localhost.sk -p 443'
alias vanguard='ssh zero@vanguard.tfx.one -p 22222'
alias sentinel='ssh zero@sentinel.tfx.one -p 22222'
alias s='sudo su -'
alias si='sudo -i'
alias ss='sudo -s'
alias su='su -'

# -----------------------------------------------------------------------------
# ls aliases.
# GNU ls uses --color=auto.
# BSD ls uses -G.
# -----------------------------------------------------------------------------

if ls --color=auto >/dev/null 2>&1; then
  alias ls='ls --color=auto'
elif ls -G >/dev/null 2>&1; then
  alias ls='ls -G'
fi

alias l='ls -lah'
alias la='ls -lah'
alias ll='ls -lh'
alias lsa='ls -lah'

# -----------------------------------------------------------------------------
# Docker wrapper.
# Uses docker directly if available for current user.
# Falls back to sudo docker when needed.
# -----------------------------------------------------------------------------

dk() {
  if ! command -v docker >/dev/null 2>&1; then
    printf 'docker not found\n' >&2
    return 127
  fi

  if docker info >/dev/null 2>&1; then
    docker "$@"
    return
  fi

  if command -v sudo >/dev/null 2>&1; then
    sudo docker "$@"
    return
  fi

  docker "$@"
}

alias dps='dk ps'
alias dpa='dk ps -a'
alias di='dk images'
alias dl='dk logs'

