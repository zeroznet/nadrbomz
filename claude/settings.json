{
  "permissions": {
    "allow": [
      "Edit",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Read(/etc/shadow*)",
      "Read(/etc/gshadow*)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/zero/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "last30days@last30days-skill": true,
    "slopbeth@slopbeth": true
  },
  "extraKnownMarketplaces": {
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    },
    "slopbeth": {
      "source": {
        "source": "github",
        "repo": "ehmo/slopbeth"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "env": {
    "LAST30DAYS_MEMORY_DIR": "/home/zero/dev/last30days"
  }
}
