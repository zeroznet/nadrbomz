# -----------------------------------------------------------------------------
# ~/.bashrc
# Personal interactive Bash config.
# Shared aliases live in ~/.shell_aliases.
# -----------------------------------------------------------------------------

# Guard: interactive shells only.
case $- in
  *i*) ;;
  *) return ;;
esac

# -----------------------------------------------------------------------------
# Path.
# -----------------------------------------------------------------------------

[ -d "$HOME/bin"  ] && PATH="$HOME/bin:$PATH"
[ -d "$HOME/sbin" ] && PATH="$HOME/sbin:$PATH"

export PATH

# -----------------------------------------------------------------------------
# Prompt.
# -----------------------------------------------------------------------------

__rb_set_prompt() {
  local c_reset='\[\e[0m\]'
  local c_user='\[\e[1;35m\]'
  local c_path='\[\e[1;34m\]'
  local c_root='\[\e[31m\]'
  local c_usermark='\[\e[32m\]'

  if [ "$EUID" -eq 0 ]; then
    PS1="${c_user}\u@\h${c_reset} at ${c_path}\w${c_reset} ${c_root}>${c_reset} "
  else
    PS1="${c_user}\u@\h${c_reset} at ${c_path}\w${c_reset} ${c_usermark}>${c_reset} "
  fi
}

PROMPT_COMMAND="__rb_set_prompt"

# -----------------------------------------------------------------------------
# Environment.
# -----------------------------------------------------------------------------

export LANG="${LANG:-en_US.UTF-8}"
export EDITOR="nvim"
export ARCHFLAGS="-arch $(uname -m)"
export PAGER="less"
export FTP_PASSIVE_MODE=1
export LESSHISTFILE=/dev/null

# -----------------------------------------------------------------------------
# LS colors.
# -----------------------------------------------------------------------------

case "$OSTYPE" in
  freebsd*)
    export CLICOLOR=1
    export LSCOLORS="Exfxcxdxbxegedabagacad"
    ;;
  linux*|cygwin*|msys*)
    export LS_COLORS="di=1;36:ln=35:so=32:pi=33:ex=31:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43"
    ;;
esac

# -----------------------------------------------------------------------------
# Less / man colors.
# -----------------------------------------------------------------------------

if [ -t 1 ]; then
  export LESS_TERMCAP_mb=$'\e[1;31m'
  export LESS_TERMCAP_md=$'\e[1;36m'
  export LESS_TERMCAP_me=$'\e[0m'
  export LESS_TERMCAP_se=$'\e[0m'
  export LESS_TERMCAP_so=$'\e[1;44;33m'
  export LESS_TERMCAP_ue=$'\e[0m'
  export LESS_TERMCAP_us=$'\e[1;32m'
fi

# -----------------------------------------------------------------------------
# Filesystem defaults.
# -----------------------------------------------------------------------------

if [ "${USER:-$(id -un)}" = "root" ]; then
  umask 022
else
  umask 077
fi

[ -d "$HOME/tmp" ] || mkdir -p "$HOME/tmp"
export TMPDIR="$HOME/tmp"

# -----------------------------------------------------------------------------
# History.
# -----------------------------------------------------------------------------

HISTSIZE=10000
HISTFILESIZE=10000
HISTCONTROL=ignoredups:erasedups

shopt -s histappend
shopt -s checkwinsize

if [ -f "$HOME/incognito_shell" ]; then
  unset HISTFILE
  set +o history
fi

# -----------------------------------------------------------------------------
# SSH keychain.
# -----------------------------------------------------------------------------

HOST="${HOST:-${HOSTNAME:-$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo unknown)}}"

if [ -f "$HOME/.ssh/keychain_enabled" ] && command -v keychain >/dev/null 2>&1; then
  keychain_args="$(cat "$HOME/.ssh/keychain_enabled")"
  keychain -q $keychain_args
  [ -f "$HOME/.keychain/${HOST}-sh" ] && . "$HOME/.keychain/${HOST}-sh"
fi

# -----------------------------------------------------------------------------
# Host-specific shell bits.
# -----------------------------------------------------------------------------

if [ "$HOST" = "USDSCWN34032527" ]; then
  if command -v kubectl >/dev/null 2>&1; then
    source <(kubectl completion bash)
  fi

  export USE_GKE_GCLOUD_AUTH_PLUGIN=True
  export AZURE_CLI_DISABLE_CONNECTION_VERIFICATION=anycontent
else
  unset MAILCHECK
fi

# -----------------------------------------------------------------------------
# Bash completion.
# -----------------------------------------------------------------------------

if [ -r /usr/share/bash-completion/bash_completion ]; then
  . /usr/share/bash-completion/bash_completion
elif [ -r /etc/bash_completion ]; then
  . /etc/bash_completion
fi

# -----------------------------------------------------------------------------
# Shared aliases and functions.
# -----------------------------------------------------------------------------

[ -r "$HOME/.shell_aliases" ] && . "$HOME/.shell_aliases"
