# -----------------------------------------------------------------------------
# ~/.ssh/config
# Personal SSH client config: known hosts and connection keepalive defaults.
# -----------------------------------------------------------------------------

Host sentinel
    HostName sentinel.tfx.one
    User zero
    Port 22222

Host vanguard
    HostName vanguard.tfx.one
    User zero
    Port 22222

Host *
    ServerAliveInterval 10
    ServerAliveCountMax 3
    TCPKeepAlive yes
    VerifyHostKeyDNS yes
