# -----------------------------------------------------------------------------
# ~/.zshrc
# Personal interactive Zsh config.
# Shared aliases live in ~/.shell_aliases.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Path.
# -----------------------------------------------------------------------------

typeset -U path PATH

[[ -d "$HOME/.local/bin" ]] && path+=("$HOME/.local/bin")
[[ -d "$HOME/bin"  ]] && path+=("$HOME/bin")
[[ -d "$HOME/sbin" ]] && path+=("$HOME/sbin")

export PATH

# -----------------------------------------------------------------------------
# Oh My Zsh.
# -----------------------------------------------------------------------------

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="minimal"

case "$OSTYPE" in
  cygwin*|msys*)
    plugins=(colored-man-pages)
    HISTORY_IGNORE='(.{100,}|*\<\<*|*EOF*)'
    DISABLE_AUTO_TITLE="true"
    ;;
  *)
    plugins=(zsh-autosuggestions colored-man-pages)
    HISTORY_IGNORE='(.{100,}|*\<\<*|*EOF*)'
    ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=5'
    ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20
    ZSH_AUTOSUGGEST_STRATEGY=(history completion)
    ;;
esac

ZSH_DISABLE_COMPFIX=true
source "$ZSH/oh-my-zsh.sh"

# -----------------------------------------------------------------------------
# Prompt.
# -----------------------------------------------------------------------------

setopt PROMPT_SUBST
setopt NO_BEEP

if [[ $EUID -eq 0 ]]; then
  PROMPT='%{$fg_bold[magenta]%}%n@%m%{$reset_color%} at %{$fg_bold[blue]%}%~%{$reset_color%} %{$fg[red]%}>%{$reset_color%} '
else
  PROMPT='%{$fg_bold[magenta]%}%n@%m%{$reset_color%} at %{$fg_bold[blue]%}%~%{$reset_color%} %{$fg[green]%}>%{$reset_color%} '
fi

RPROMPT=''

# -----------------------------------------------------------------------------
# Environment.
# -----------------------------------------------------------------------------

export LANG="${LANG:-en_US.UTF-8}"
export EDITOR="nvim"
export ARCHFLAGS="-arch $(uname -m)"
export PAGER="less"
export FTP_PASSIVE_MODE=1
export LESSHISTFILE=/dev/null

# -----------------------------------------------------------------------------
# LS colors.
# -----------------------------------------------------------------------------

case "$OSTYPE" in
  freebsd*)
    export CLICOLOR=1
    export LSCOLORS="Exfxcxdxbxegedabagacad"
    ;;
  linux*|cygwin*|msys*)
    export LS_COLORS="di=1;36:ln=35:so=32:pi=33:ex=31:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43"
    ;;
esac

# -----------------------------------------------------------------------------
# Filesystem defaults.
# -----------------------------------------------------------------------------

if [[ $USER == root ]]; then
  umask 022
else
  umask 077
fi

[[ -d "$HOME/tmp" ]] || mkdir -p "$HOME/tmp"
export TMPDIR="$HOME/tmp"

# -----------------------------------------------------------------------------
# History.
# -----------------------------------------------------------------------------

if [[ -f "$HOME/incognito_shell" ]]; then
  unset HISTFILE
  setopt HIST_IGNORE_ALL_DUPS
  setopt SHARE_HISTORY
  setopt HIST_NO_STORE
fi

# -----------------------------------------------------------------------------
# SSH keychain.
# -----------------------------------------------------------------------------

if [[ -f "$HOME/.ssh/keychain_enabled" ]] && command -v keychain >/dev/null 2>&1; then
  keychain_args=$(cat "$HOME/.ssh/keychain_enabled")
  keychain -q $keychain_args
  [[ -f "$HOME/.keychain/${HOST}-sh" ]] && . "$HOME/.keychain/${HOST}-sh"
fi

# -----------------------------------------------------------------------------
# Optional autosuggest accept binding.
# Disabled per your ask. Leave commented unless you want it back.
# -----------------------------------------------------------------------------

# if (( $+widgets[autosuggest-accept] )); then
#   bindkey '^E' autosuggest-accept
# fi

# -----------------------------------------------------------------------------
# Host-specific shell bits.
# -----------------------------------------------------------------------------

if [[ "$HOST" == "USDSCWN34032527" ]]; then
  if command -v kubectl >/dev/null 2>&1; then
    source <(kubectl completion zsh)
  fi
  export USE_GKE_GCLOUD_AUTH_PLUGIN=True
  export AZURE_CLI_DISABLE_CONNECTION_VERIFICATION=anycontent
else
  unset MAILCHECK
fi

# -----------------------------------------------------------------------------
# Shared aliases and functions.
# Keep this near the end so it can override plugin aliases cleanly.
# -----------------------------------------------------------------------------

[[ -r "$HOME/.shell_aliases" ]] && . "$HOME/.shell_aliases"
